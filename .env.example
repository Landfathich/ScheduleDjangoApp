# Server connection
SERVER_IP=your_server_ip
SERVER_PORT=your_ssh_port
SERVER_USER=your_username
SERVER_PASS=your_password

# Root password (if needed)
ROOT_PASS=your_root_password

# Server name
SERVER_PC_NAME=your_server_name

# Website passwords (different environments)
WEBSITE_TEST_PASS=your_test_password
WEBSITE_PROD_PASS=your_prod_password
WEBSITE_DEBUG_PASS=your_debug_password

# VAPID keys for Web Push (generate your own)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key